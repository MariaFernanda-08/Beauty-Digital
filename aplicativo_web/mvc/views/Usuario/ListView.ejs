<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <title>List</title>

    <style>
         *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body{
            background: linear-gradient(135deg, #f8c8dc, #b57edc);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 30px;
        }

        .title{
            text-align: center;
            margin-bottom: 30px;
            color: #b380d3;
            font-weight: 700;
        }

        .table-container{
            background: white;
            padding: 40px;
            border-radius: 25px;
            width: 60%;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }

        .table thead{
            background: #b380d3;
            color: white;
        }

        .btn-edit{
            background: rgb(127, 59, 179);
            color: white;
            border: none;
            padding: 8px 14px;
            border-radius: 10px;
            text-decoration: none;
        }

        .btn-delete{
            background:#b9354d;
            color: white;
            border: none;
            padding: 8px 14px;
            border-radius: 10px ;
        }

        .btn-edit:hover, .btn-delete:hover{
            opacity: 0.8;
        }

        .sidebar{
            width: 100px;
            background:white;
            height: 100vh;
            padding: 30px 20px;
            box-shadow: 5px 0 20px rgba(0, 0, 0, 0.08);
            display: flex;
            flex-direction: column;
            position: fixed;
            left: 0;
            top: 0;
        }

        .logo-area{
            text-align: center;
            margin-bottom: 40px;    
        }

        .logo-title{
            color: #b380d3;
            font-size: 1.0rem;
            font-weight: 700;
        }

        .sidebar-menu{
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .menu-item{
            text-decoration: none;
            color: #555;
            padding: 14px;
            border-radius: 12px;
            transition: 0.3s;

            display: flex;
            align-items: center;
            justify-content: center;

            font-size: 1.2rem;
        }

        .menu-item:hover{
            background: #f4e5ff;
            color: #b380d3;
            transform: translateX(5px);
        }

        .menu-active{
            background: linear-gradient(90deg,#b57edc);
            color: white;
        }

        .content{
            margin-left: 260px;
            width: calc(100% - 260px);

            display: flex;
            justify-content: center;
            align-items: center;

            padding: 40px;
        } 

    </style>
</head>
<body>
    <div class="sidebar">
        <div class="logo-area">
            <h2 class="logo-title">Beauty Digital</h2>
        </div>
        <div class="sidebar-menu">
            <a href="/user/create" class="menu-item">
                <i class="bi bi-person-plus"></i></a>
            <a href="/user/list" class="menu-item menu-active">
                <i class="bi bi-person"></i></a>
        </div>
    </div>
    <div class="content">
        <div class="table-container">
                <h1 class="title">Lista de Usuários</h1>
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Senha</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for(usuario of usuarios) {%>
                            <tr>
                                <td><%= usuario.id %></td>
                                <td><%= usuario.nome %></td>
                                <td><%= usuario.email %></td>
                                <td>••••••</td>
                                <td class="d-flex gap-2">
                                    <a href="/user/edit/<%= usuario.id %>" class="btn-edit">Editar</a>
                                    <button onclick="apagarUsuario('<%= usuario.id %>')" id="btnApagar" class="btn-delete">Apagar</button>
                                </td>
                            </tr>
                        <% } %>    
                    </tbody>
                </table>
        </div>
    </div>
</body>
<script>
    async function apagarUsuario(id){
        const url = "/user/delete/"+id
        const response = await fetch(url, {method:'DELETE'})

        const data = await response.json()

        if(!response.ok){
            console.log("Ocorreu um erro na requisição")
        }

        console.log(data)
        location.reload()
    }
</script>
</html>