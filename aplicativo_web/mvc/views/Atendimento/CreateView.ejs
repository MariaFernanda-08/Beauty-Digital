<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <title>Criar Atendimento</title>

    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body{
            background: linear-gradient(135deg,  #f8c8dc, #b57edc);
            min-height: 100vh;
            display: flex;
        }

        .container-custom{
            background:white;
            width: 100%;
            max-width: 850px;
            padding: 40px;
            border-radius: 25px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);

            margin: auto;
        }

        .title{
            text-align: center;
            margin-bottom: 30px;
            color: #b380d3;
            font-weight: 700;
        }

        .form-label{
            font-weight: 500;
            color: #555;
        }

        .form-control{
            border-radius: 12px;
            padding: 12px;
            border: 1px solid #ddd;
            transition: 0.3s;
        }

        .form-control:focus{
            border-color: #8210d3;
            box-shadow: 0 0 0 0.2rem rgba(219, 11, 191, 0.2);
        }

        .btn-custom{
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(90deg,#b57edc);
            color: white;
            font-weight: 600;
            transition: 0.3s;
        }

        .btn-custom:hover{
            transform: translateY(-2px);
            opacity: 0.9;
        }

        .sidebar{
            width: 100px;
            background:white;
            height: 100vh;
            padding: 30px 20px;
            box-shadow: 5px 0 20px rgba(0, 0, 0, 0.08);
            display: flex;
            flex-direction: column;
            position: fixed;
            left: 0;
            top: 0;
        }

        .logo-area{
            text-align: center;
            margin-bottom: 40px;   
        }

        .logo-title{
            color: #b380d3;
            font-size: 1.0rem;
            font-weight: 700;
        }

        .sidebar-menu{
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .menu-item{
            text-decoration: none;
            color: #555;
            padding: 14px;
            border-radius: 12px;
            transition: 0.3s;

            display: flex;
            align-items: center;
            justify-content: center;
            gap: 20px;

            font-weight: 200;
            background: #f4e8fd;
            font-size: 1.2rem;
        }

        .menu-item:hover{
            background: #f4e5ff;
            color: #b380d3;
            transform: translateX(5px);
        }

        .menu-active{
            background: linear-gradient(90deg,#b57edc);
            color: white;
        }

        .content{
            margin-left: 100px;
            width: calc(100% - 100px);
            min-height: 100vh;

            display: flex;
            justify-content: center;
            align-items: center;

            padding: 40px;
        } 

        .subtitle{
            text-align: center;
            color: #888;
            margin-top: -15px;
            margin-bottom: 30px;
        }

        .row{
            row-gap: 5px;
        }

        @media(max-width: 768px){
            .container-custom{
                padding: 25px;
            }
            .title{
                font-size: 2rem;
            }
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="logo-area">
            <h2 class="logo-title">Beauty Digital</h2>
        </div>
        <div class="sidebar-menu">
            <a href="/user/create" class="menu-item">
                <i class="bi bi-person-plus"></i></a>
            <a href="/user/list" class="menu-item">
                <i class="bi bi-person"></i></a>
            <a href="/atendimento/create" class="menu-item menu-active">
                <i class="bi bi-calendar-plus"></i></a>
            <a href="/atendimento/list" class="menu-item">
                <i class="bi bi-calendar-check"></i></a>
        </div>
    </div>
    <div class="content">
        <div class="container-custom">
        <form>
            <h1 class="title">Cadastro de Atendimento</h1>
            <p class="subtitle">Agende seu horário no nosso salão!</p>
            <div class="row">
                <div class="col-6 mb-3">
                    <div>
                        <label for="nomeCliente" class="form-label">Nome do Cliente</label>
                        <input type="text" id="nomeCliente" class="form-control">
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div>
                        <label for="telefone" class="form-label">Telefone</label>
                        <input type="tel" id="telefone" class="form-control">
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div>
                        <label for="data" class="form-label">Data do Atendimento</label>
                        <input type="date" id="data" class="form-control">
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div>
                        <label for="horario" class="form-label">Horário do Atendimento</label>
                        <input type="time" id="horario" class="form-control">
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div>
                        <label for="dataNascimento" class="form-label">Data de Nascimento</label>
                        <input type="date" id="dataNascimento" class="form-control">
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div>
                        <label for="tipoServico" class="form-label">Tipo de Serviço</label>
                        <select id="tipoServico" class="form-control">
                            <option value="">Selecione</option>
                            <option>Cabelo</option>
                            <option>Unha</option>
                            <option>Pele</option>
                        </select>
                    </div>
                </div>
                <div class="col-12 mb-4">
                    <div>
                        <label for="profissional" class="form-label">Profissional</label>
                        <select id="profissional">
                            <% for(const usuario of usuarios) {%>
                                <option value="<%= usuario.id %>"><%= usuario.nome %></option>
                            <% } %>  
                        </select>
                    </div>
                </div>
                <div>
                    <button type="submit" id="btnCadastrarAtendimento" class="btn-custom">Agendar</button>
                </div>
            </div>
        </form>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
<script>

    const btnCadastrarAtendimento = document.getElementById("btnCadastrarAtendimento")
    btnCadastrarAtendimento.addEventListener("click", cadastrarAtendimento)

    async function cadastrarAtendimento(e){
        e.preventDefault()
        
        const nomeCliente = document.getElementById("nomeCliente")
        const telefone = document.getElementById("telefone")
        const horario = document.getElementById("horario")
        const data = document.getElementById("data")
        const dataNascimento = document.getElementById("dataNascimento")
        const tipoServico = document.getElementById("tipoServico")
        const profissional = document.getElementById("profissional")

        if(nomeCliente.value === "" || //validação dos campos
            telefone.value === "" ||
            horario.value === "" ||
            data.value === "" ||
            dataNascimento.value === "" ||
            tipoServico.value === "" ||
            profissional.value === "" 
        ){ 
            Swal.fire({
                title: 'Campos Obrigatórios',
                text: 'Preencha todos os campos.',
                icon: 'warning',
                confirmButtonColor: '#b57edc'
            })
            return
        } 

        try{
            const url = "/atendimento/create"
            const response = await fetch(url, {
                method:'POST',
                headers:{
                    'Content-Type':'application/json'
                },
                body: JSON.stringify(
                    {
                        nomeCliente: nomeCliente.value,
                        telefone: telefone.value,
                        horario: horario.value,
                        data: data.value,
                        dataNascimento: dataNascimento.value,
                        tipoServico: tipoServico.value,
                        profissional: profissional.value,
                    }
                )
            })

            const data = await response.json()

            if(!response.ok){
                Swal.fire({
                    title: 'Erro!',
                    text: 'Não foi possível cadastrar.',
                    icon: 'error',
                    confirmButtonColor: '#b57edc'
                })
                return
            }
            Swal.fire({
                title: 'Atendimento agendado!',
                text: 'Cadastro realizado com sucesso.',
                icon: 'success',
                confirmButtonColor: '#b57edc'
            })
            console.log(data)

            // limpa os campos depois da criação
            nomeCliente.value === "" 
            telefone.value === "" 
            horario.value === "" 
            data.value === "" 
            dataNascimento.value === "" 
            tipoServico.value === "" 
            profissional.value === "" 

            //redireciona
            setTimeout(() => {
                window.location.href = "/atendimento/list"
            },1500)
        }catch(erro){
            console.log(erro)
            
            Swal.fire({
                title: 'Erro interno',
                text: 'Tente novamente.',
                icon: 'error',
                confirmButtonColor: '#b57edc'
            })
        }
    }
</script>
</html>